# Rolfing Web Project - Environment Variables Example
# Copia este archivo a .env y actualiza los valores con tus datos

# ===================================
# ENTORNO
# ===================================
ENVIRONMENT=development
# ENVIRONMENT=production

# ===================================
# PUERTO
# ===================================
APP_PORT=8080

# ===================================
# INFORMACIÓN DEL NEGOCIO
# ===================================
BUSINESS_NAME=Rolfing Terapia
BUSINESS_EMAIL=info@rolfing.com
BUSINESS_PHONE=+1 (234) 567-8900
BUSINESS_LOCATION=Calle Principal #123

# ===================================
# BASE DE DATOS
# ===================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rolfing_db
DB_USER=root
DB_PASSWORD=password
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ===================================
# EMAIL
# ===================================
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=jmmartinezastroza@gmail.com
MAIL_SMTP_PASSWORD=123qwerty

# ===================================
# SEGURIDAD
# ===================================
JWT_SECRET=123qwerty
CORS_ENABLED=true

# ===================================
# LOGGING
# ===================================
LOG_LEVEL=INFO
LOG_FILE=logs/rolfing.log

# ===================================
# CACHÉ
# ===================================
CACHE_ENABLED=true
CACHE_TTL=3600

# ===================================
# URLS
# ===================================
APP_URL=http://localhost:8080/rolfing
# APP_URL=https://www.midominio.com (producción)
